{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Sandwich app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "xattr",
          "cmd": "/usr/bin/xattr",
          "args": true
        }
      ]
    },
    "dialog:default",
    {
      "identifier": "dialog:allow-open",
      "allow": [
        {
          "directory": true
        }
      ]
    },
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    }
  ]
}
